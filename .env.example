# ---------------------------------------------------------------------------
# Supabase connection settings (TEMPLATE - no real secrets in this file)
#
# HOW TO USE:
#   1. Copy this file to a new file named ".env.local"
#   2. Replace the placeholder values with the real ones from your Supabase
#      dashboard: Project Settings -> API Keys (and Settings -> Data API for the URL)
#   3. ".env.local" is git-ignored, so your real keys never get committed.
#
# STAGING (Cloudflare Workers):
#   Use a SEPARATE Supabase project (no real student data). Same variable names.
#   Set the same three values as Cloudflare Worker vars/secrets, and as
#   Workers Builds "Build variables and secrets" when using CI.
#   For `npm run preview`, also copy `.dev.vars.example` to `.dev.vars`.
# ---------------------------------------------------------------------------

# Project URL. Found under: Project Settings -> Data API -> Project URL
# PUBLIC (safe in browser; also required at build time for Next).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Public "anon" / "publishable" key. Found under: Project Settings -> API Keys.
# PUBLIC — Row Level Security protects your data.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"

# Secret "service_role" key. Found under: Project Settings -> API Keys.
# SECRET — SERVER-SIDE ONLY (Cloudflare Secret). Bypasses RLS.
# Never prefix it with NEXT_PUBLIC and never import it into browser code.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"
