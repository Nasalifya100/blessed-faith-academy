# ---------------------------------------------------------------------------
# Supabase connection settings (TEMPLATE - no real secrets in this file)
#
# HOW TO USE:
#   1. Copy this file to a new file named ".env.local"
#   2. Replace the placeholder values with the real ones from your Supabase
#      dashboard: Project Settings -> API Keys (and Settings -> Data API for the URL)
#   3. ".env.local" is git-ignored, so your real keys never get committed.
#
# STAGING (Cloudflare Workers):
#   Use a SEPARATE Supabase project (no real student data). Same variable names.
#   Also set Auth redirect URLs in the Supabase dashboard (see docs / password reset).
#
#   Where Cloudflare expects the public vars (build + runtime):
#     Dashboard → Workers → bfa-sms-staging → Settings → Variables and Secrets
#       NEXT_PUBLIC_SUPABASE_URL        → Variable (plain)
#       NEXT_PUBLIC_SUPABASE_ANON_KEY   → Variable (plain)
#       NEXT_PUBLIC_SITE_URL            → Variable (plain) e.g. https://bfa-sms-staging….workers.dev
#       SUPABASE_SERVICE_ROLE_KEY       → Secret (never NEXT_PUBLIC_)
#     Also set the same under Build variables and secrets if using Workers Builds.
#   Local: this file → .env.local; for preview copy .dev.vars.example → .dev.vars
# ---------------------------------------------------------------------------

# Project URL. Found under: Project Settings -> Data API -> Project URL
# PUBLIC (safe in browser; also required at build time for Next).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Public "anon" / "publishable" key. Found under: Project Settings -> API Keys.
# PUBLIC — Row Level Security protects your data.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"

# Public site origin used for Auth email redirects (no trailing slash).
# Local next dev: http://localhost:3000
# Staging Worker / local `npm run deploy` build: MUST be the public staging origin
#   https://bfa-sms-staging.nasalifya007.workers.dev
# Do not build/deploy the Worker with localhost here — reset emails will point at localhost.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Secret "service_role" key. Found under: Project Settings -> API Keys.
# SECRET — SERVER-SIDE ONLY (Cloudflare Secret). Bypasses RLS.
# Never prefix it with NEXT_PUBLIC and never import it into browser code.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"
