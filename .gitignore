# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# OpenNext / Cloudflare Workers
.open-next/
.wrangler/
.dev.vars

# Database dumps / sensitive exports (never commit)
*.dump
*.pgdump
*.sql.gz
*.sql.bak
/db-dumps/
/dumps/

# production
/build

# misc
.DS_Store
*.pem

# Local cleanup inventory artefacts (may contain emails / ids)
scripts/.staff-test-inventory.json
scripts/.staff-test-cleanup-result.json
scripts/.finance-test-*.json
scripts/.phase2a-staging-verify-result.json
scripts/.phase2b-staging-verify-result.json
scripts/.migration-reconciliation-*.json

# Supabase CLI local link cache (may include pooler URLs)
supabase/.temp/
.supabase/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but DO commit the template (it contains no real secrets)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
